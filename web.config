<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <system.webServer>
    <!-- Disable directory listing for security -->
    <directoryBrowse enabled="false" />

    <!-- Register iisnode handler for the production transpiled server script -->
    <handlers>
      <clear />
      <add name="iisnode" path="dist/server.js" verb="*" modules="iisnode" />
    </handlers>

    <!-- Configure URL rewriting to route all API and routing traffic to Express -->
    <rewrite>
      <rules>
        <!-- Ensure Node Inspector and debug routes bypass rewriting -->
        <rule name="NodeInspector" patternSyntax="ECMAScript" stopProcessing="true">
          <match url="^dist/server.js/_inspector" />
        </rule>

        <!-- Bypass rewriting for the logs folder to allow web access to stdout files -->
        <rule name="LogFiles" stopProcessing="true">
          <match url="^iisnode/.*" />
        </rule>

        <!-- Route all incoming HTTP requests to Express router through dist/server.js -->
        <rule name="DynamicContent">
          <conditions>
            <!-- Do not rewrite requests for actual files existing on disk -->
            <add input="{REQUEST_FILENAME}" matchType="IsFile" negate="true" />
          </conditions>
          <action type="Rewrite" url="dist/server.js" />
        </rule>
      </rules>
    </rewrite>

    <!-- Configure iisnode runtime options for Plesk environment -->
    <iisnode 
      watchedFiles="web.config;dist\*.js" 
      loggingEnabled="true" 
      stdoutLogEnabled="true"
      logDirectory="iisnode"
      devErrorsEnabled="false"
      nodeProcessCountPerApplication="1"
      maxConcurrentRequestsPerProcess="1024"
      maxNamedPipeConnectionRetry="100"
      namedPipeConnectionRetryDelay="250"
    />
  </system.webServer>

  <!-- Keep Plesk default compilation settings to avoid temp directory access issues -->
  <system.web>
    <compilation tempDirectory="D:\Inetpub\vhosts\kiwiclicks.in\tmp" />
  </system.web>
</configuration>
